# =============================================================================
# StitchWise — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Dataset & large data files (never commit raw or processed datasets)
# -----------------------------------------------------------------------------
data/raw/
data/rescuenet_yolo/
data/aerial234/
*.jpg
*.jpeg
*.png
*.tif
*.tiff

# -----------------------------------------------------------------------------
# Model weights (large binary files — share via Google Drive / HuggingFace)
# -----------------------------------------------------------------------------
detection/model/
*.pt
*.pth
*.onnx
*.engine

# -----------------------------------------------------------------------------
# Training outputs (logs, plots, weights written by YOLOv8)
# -----------------------------------------------------------------------------
outputs/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
venv/
.venv/
env/
.env/

# -----------------------------------------------------------------------------
# Jupyter notebooks (checkpoints)
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------

# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~

# -----------------------------------------------------------------------------
# IDEs
# -----------------------------------------------------------------------------

# VSCode
.vscode/
*.code-workspace

# PyCharm
.idea/

# -----------------------------------------------------------------------------
# Kaggle credentials (never commit)
# -----------------------------------------------------------------------------
kaggle.json
*.token

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.log
*.tmp
*.bak